NODE_ENV=development

# CORS / app URLs — thay bằng LAN IP nếu cần truy cập từ mobile trong cùng mạng.
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Local infra — dùng localhost khi chạy pnpm dev. Nếu chạy api trong docker
# compose thì đổi hostname thành tên service (postgres / redis / minio).
DATABASE_URL=postgresql://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379

# JWT — PHẢI sinh random 64-char hex mới cho mỗi lần cài. Không copy nguyên
# giá trị mẫu này.
# PowerShell:  -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
# Bash:        openssl rand -hex 32
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# S3 / MinIO — trỏ về container MinIO trong docker-compose. Bucket phải tạo
# thủ công (`mc mb liteerp/refurb-attachments` hoặc console web :9001).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=refurb-attachments
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345

# SMTP — chưa dùng, để trống.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Drive — để trống → DriveService chạy DEGRADED (upload sẽ fail nhưng
# API không crash). Muốn bật, chạy: pnpm --filter @app/api exec ts-node scripts/drive-oauth-init.ts
# và xem docs/DRIVE_SETUP.md.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Backup — mặc định off; bật bằng BACKUP_ENABLED=true nếu muốn cron 3am hàng ngày.
BACKUP_ENABLED=false
BACKUP_CRON=0 3 * * *
BACKUP_TIMEZONE=Asia/Ho_Chi_Minh
BACKUP_STRATEGY=docker
BACKUP_DOCKER_CONTAINER=refurb-postgres
