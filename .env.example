NODE_ENV=production

APP_URL=https://example.com
API_URL=https://api.example.com

# SQLite — path relative to apps/api/prisma/ (Prisma resolves file: URLs from
# schema.prisma dir). On Android/embedded builds, override to an absolute path
# inside the app's writable data dir.
DATABASE_URL=file:../data/liteerp.sqlite

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Local FS upload dir for attachments (replaces S3/MinIO).
UPLOAD_DIR=./data/uploads

# --- Google Drive (Phase 1.5 drive integration) ---
# Follow docs/DRIVE_SETUP.md to obtain these values.
# Leave blank to disable — the DriveService will run in DEGRADED mode and
# reject uploads with DRIVE_NOT_CONFIGURED until they are set.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Backup schedule (SQLite: `PRAGMA wal_checkpoint` + copy file, no pg_dump).
BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_TIMEZONE=Asia/Ho_Chi_Minh

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
