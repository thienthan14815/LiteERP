# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# SQLite (on-device DB lives under apps/api/data; never commit DB files)
**/data/*.sqlite
**/data/*.sqlite-*
**/*.sqlite-journal

# Env files
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Test / coverage
coverage/
.nyc_output/

# Docker volumes (local)
docker/data/
docker/volumes/

# Uploads (local dev)
uploads/
tmp/
# NOTE: pnpm-lock.yaml is intentionally COMMITTED (reproducible installs +
# --frozen-lockfile in CI/APK build). Do not add it here.

# Payload zip nhúng vào APK (~295 MB — build lại từ payload/ bằng scripts/build-payload.sh)
payload.zip

# Capacitor / Android
android/.gradle/
android/.idea/
android/local.properties
android/app/build/
android/build/
android/captures/
android/app/release/
*.keystore
*.jks
keystore.properties
